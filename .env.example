# Copy this file to .env.local and fill values

# ==== PORTFOLIO AUTHENTICATION ====

# OPTION 1: Bcrypt hash (RECOMMENDED for production)
# Generate with: node scripts/generate-password-hash.js YOUR_PASSWORD
# IMPORTANT: Escape $ characters with backslash (\$) to prevent variable interpolation
# PORTFOLIO_PASSWORD_HASH=\$2b\$10\$...your_hash_here...

# OPTION 2: Plain text password (DEPRECATED - only for development)
# PORTFOLIO_PASSWORD=your_password_here

# Long random secret used to sign auth tokens (keep private)
# Generate with: openssl rand -hex 64
PORTFOLIO_AUTH_SECRET=replace_with_a_long_random_secret

# ==== CLOUDFLARE TURNSTILE ====
# Get keys from: https://dash.cloudflare.com/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
# TURNSTILE_SECRET_KEY=your_secret_key_here

# ==== CLOUDFLARE WEB ANALYTICS ====
# Get token from: https://dash.cloudflare.com/web-analytics
# NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=your_token_here

# ==== WEB3FORMS (Contact Form) ====
# Get key from: https://web3forms.com
# WEB3FORMS_ACCESS_KEY=your_access_key_here

# Optional: NODE_ENV=development
